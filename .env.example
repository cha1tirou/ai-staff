# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# PostgreSQL接続URL（Neon無料枠 or Railway Postgres）
# Neon: https://neon.tech で無料DB作成 → 接続文字列をコピー
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT署名シークレット（任意の長い文字列）
JWT_SECRET=your-super-secret-key-change-this

# App
NEXT_PUBLIC_APP_URL=https://ai-staff-rho.vercel.app
